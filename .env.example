# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template cho file .env (KHÔNG commit .env lên git)
#
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env
#
# Viper đọc biến env với prefix APARTMENT_APP_ và tự ánh xạ vào config struct.
# Key mapping: APARTMENT_APP_DATABASE_MYSQL_PASSWORD → database.mysql.password
# ─────────────────────────────────────────────────────────────────────────────

# ── Database MySQL ────────────────────────────────────────────────────────────
APARTMENT_APP_DATABASE_MYSQL_HOST=service-mysql
APARTMENT_APP_DATABASE_MYSQL_PORT=3306
APARTMENT_APP_DATABASE_MYSQL_DATABASE=aklht_apartment
APARTMENT_APP_DATABASE_MYSQL_USERNAME=root
APARTMENT_APP_DATABASE_MYSQL_PASSWORD=change_me_in_production

# ── Redis ─────────────────────────────────────────────────────────────────────
APARTMENT_APP_DATABASE_REDIS_HOST=apartment_redis
APARTMENT_APP_DATABASE_REDIS_PORT=6379
APARTMENT_APP_DATABASE_REDIS_PASSWORD=

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# APARTMENT_APP_DATABASE_ELASTICSEARCH_ADDRESSES=http://apartment_elasticsearch:9200
APARTMENT_APP_DATABASE_ELASTICSEARCH_USERNAME=elastic
APARTMENT_APP_DATABASE_ELASTICSEARCH_PASSWORD=change_me_in_production

# ── JWT ───────────────────────────────────────────────────────────────────────
APARTMENT_APP_JWT_ACCESS_SECRET=change_me_to_strong_random_secret_min_32chars
APARTMENT_APP_JWT_REFRESH_SECRET=change_me_to_another_strong_random_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
APARTMENT_APP_AUTH_GOOGLE_CLIENT_ID=your_google_client_id
APARTMENT_APP_AUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
APARTMENT_APP_AUTH_GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# ── Cloudinary ────────────────────────────────────────────────────────────────
APARTMENT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name
APARTMENT_APP_CLOUDINARY_API_KEY=your_api_key
APARTMENT_APP_CLOUDINARY_API_SECRET=your_api_secret

# ── Mailer ────────────────────────────────────────────────────────────────────
APARTMENT_APP_MAILER_SMTP_USER=your_email@gmail.com
APARTMENT_APP_MAILER_SMTP_PASS=your_app_password
APARTMENT_APP_MAILER_FROMNAME=Apartment Service
